NODE_ENV=development
PORT=3000
HOST=127.0.0.1

SESSION_SECRET=change_me_to_a_long_random_value
ADMIN_PATH=panel-change-me

DB_HOST=localhost
DB_PORT=3306
DB_NAME=polskiebudownictwo
DB_USER=polskiebudownictwo_user
