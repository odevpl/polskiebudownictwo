{
  "name": "polskiebudownictwo",
  "version": "1.0.0",
  "private": true,
  "description": "Strona inicjatywy Polskie Budownictwo",
  "main": "app.js",
  "scripts": {
    "dev": "node --watch --watch-path=page --watch-path=views --watch-path=public --watch-path=controllers --watch-path=models --watch-path=routes --watch-path=services server.js",
    "watch": "node --watch --watch-path=page --watch-path=views --watch-path=public --watch-path=controllers --watch-path=models --watch-path=routes --watch-path=services server.js",
    "serve": "node server.js",
    "start": "node --watch --watch-path=page --watch-path=views --watch-path=public --watch-path=controllers --watch-path=models --watch-path=routes --watch-path=services app.js",
    "start:prod": "node app.js",
    "mediacje": "node --watch --watch-path=subdomain/mediacje --watch-path=app-mediacje.js scripts/runMediacje.js",
    "dev:mediacje": "node --watch --watch-path=subdomain/mediacje --watch-path=app-mediacje.js scripts/runMediacje.js",
    "mediacje:dist": "npm run build:mediacje && node dists/mediacje.polskiebudownictwo.org/app.js",
    "migrate": "node scripts/migrate.js",
    "create-superadmin": "node scripts/createSuperadmin.js",
    "reset-admin-password": "node scripts/resetAdminPassword.js",
    "test:smtp": "node scripts/testSmtp.js",
    "build:main": "node scripts/buildDeployPackage.js main",
    "build:mediacje": "node scripts/buildDeployPackage.js mediacje",
    "build:deploy": "node scripts/buildDeployPackage.js",
    "dist": "node scripts/buildDeployPackage.js"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "bcrypt": "^6.0.0",
    "connect-flash": "^0.1.1",
    "dotenv": "^17.4.2",
    "ejs": "^6.0.1",
    "express": "^4.19.2",
    "express-mysql-session": "^3.0.3",
    "express-rate-limit": "^8.5.2",
    "express-session": "^1.19.0",
    "express-validator": "^7.3.2",
    "helmet": "^8.2.0",
    "mysql2": "^3.22.5",
    "nodemailer": "^9.0.1"
  }
}
