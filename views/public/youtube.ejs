<!doctype html>
<html lang="pl">
  <head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="icon" type="image/png" href="/assets/favicon-144x144.png">
    <title><%= title %></title>
    <link rel="stylesheet" href="/global.css?v=5">
    <style>
      body {
        background: var(--color-dark);
      }

      .youtube-page {
        min-height: calc(100dvh - 190px);
        padding-block: clamp(7rem, 12vw, 9rem) clamp(3rem, 7vw, 5rem);
        background:
          radial-gradient(circle at 20% 10%, rgb(238 35 41 / 18%), transparent 32rem),
          var(--color-dark);
      }

      .youtube-video {
        overflow: hidden;
        aspect-ratio: 16 / 9;
        border: 1px solid rgb(255 255 255 / 12%);
        border-radius: var(--radius-md);
        background: #000;
        box-shadow: var(--shadow-lg);
      }

      .youtube-video iframe {
        display: block;
        width: 100%;
        height: 100%;
        border: 0;
      }
    </style>
  </head>
  <body>
    <header class="site-header">
      <div class="container site-header__inner">
        <a class="site-logo" href="/" aria-label="Polskie Budownictwo - strona glowna">
          <img src="/assets/images/logo.png" alt="Polskie Budownictwo">
        </a>

        <button class="site-menu-toggle" type="button" aria-controls="site-nav" aria-expanded="false" aria-label="Otwórz menu">
          <span></span>
          <span></span>
          <span></span>
        </button>

        <nav class="site-nav" id="site-nav" aria-label="Glowna nawigacja">
          <a href="/#misja">Misja</a>
          <a href="/#dzialania">Obszary działania</a>
          <a href="/o_fundacji.html">O fundacji</a>
          <a href="/#spolecznosc">Społeczność</a>
          <a href="/#kontakt">Kontakt</a>
          <a
            class="social-link social-link--icon"
            href="https://www.linkedin.com/newsletters/polskie-budownictwo-7446992061150584832/"
            target="_blank"
            rel="noopener noreferrer"
            aria-label="Newsletter Polskie Budownictwo na LinkedIn"
          >
            <svg aria-hidden="true" viewBox="0 0 24 24"><path d="M6.5 8.25H3V21h3.5V8.25ZM4.75 3A2.06 2.06 0 1 0 4.75 7.12 2.06 2.06 0 0 0 4.75 3ZM21 13.69c0-3.84-2.05-5.63-4.79-5.63a4.15 4.15 0 0 0-3.77 2.07h-.05V8.25H9.03V21h3.5v-6.31c0-1.66.31-3.28 2.38-3.28 2.04 0 2.06 1.91 2.06 3.39V21H21v-7.31Z"></path></svg>
          </a>
          <a class="button button--nav" href="/#dolacz">Dołącz bezpłatnie</a>
        </nav>

        <a class="button button--nav site-header__mobile-cta" href="/#dolacz">Dołącz</a>
      </div>
    </header>

    <main class="youtube-page">
      <div class="container">
        <div class="youtube-video">
          <iframe
            src="https://www.youtube.com/embed/<%= videoId %>?controls=0"
            title="YouTube video player"
            allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
            referrerpolicy="strict-origin-when-cross-origin"
            allowfullscreen
          ></iframe>
        </div>
      </div>
    </main>

    <footer class="site-footer">
      <div class="container site-footer__inner">
        <a class="site-logo site-logo--footer" href="/" aria-label="Polskie Budownictwo">
          <img src="/assets/images/logo.png" alt="Polskie Budownictwo">
        </a>
        <p>© 2026 Polskie Budownictwo. Wszelkie prawa zastrzeżone.</p>
        <nav class="site-footer__links" aria-label="Dokumenty prawne">
          <a
            class="social-link social-link--icon"
            href="https://www.linkedin.com/newsletters/polskie-budownictwo-7446992061150584832/"
            target="_blank"
            rel="noopener noreferrer"
            aria-label="Newsletter Polskie Budownictwo na LinkedIn"
          >
            <svg aria-hidden="true" viewBox="0 0 24 24"><path d="M6.5 8.25H3V21h3.5V8.25ZM4.75 3A2.06 2.06 0 1 0 4.75 7.12 2.06 2.06 0 0 0 4.75 3ZM21 13.69c0-3.84-2.05-5.63-4.79-5.63a4.15 4.15 0 0 0-3.77 2.07h-.05V8.25H9.03V21h3.5v-6.31c0-1.66.31-3.28 2.38-3.28 2.04 0 2.06 1.91 2.06 3.39V21H21v-7.31Z"></path></svg>
          </a>
          <a href="/assets/documents/legal/polityka-prywatnosci.pdf" target="_blank" rel="noopener">Polityka prywatności</a>
          <a href="/assets/documents/legal/polityka-prywatnosci.pdf" target="_blank" rel="noopener">Polityka cookies</a>
        </nav>
      </div>
    </footer>
    <script src="/assets/js/menu.js?v=2" defer></script>
  </body>
</html>
