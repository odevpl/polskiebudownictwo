<!doctype html>
<html lang="pl">
  <head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta name="robots" content="noindex, nofollow">
    <title><%= title %> | Akademia</title>
    <link rel="stylesheet" href="/global.css">
  </head>
  <body class="academy-page">
    <header class="site-header"><div class="container site-header__inner"><a class="site-logo" href="/akademia/" aria-label="Akademia Polskiego Budownictwa"><img src="/assets/images/logo.png" alt="Polskie Budownictwo"></a><nav class="site-nav" aria-label="Główna nawigacja"><a href="/akademia/">Dostępne kursy</a><a href="/akademia/ustawienia/">Ustawienia konta</a><a href="/o_fundacji.html">O fundacji</a></nav></div></header>
    <main class="academy-detail"><section class="section section--dark academy-courses__hero"><div class="container"><p class="eyebrow"><%= course.title %></p><h1><%= lesson.title %></h1><p class="lead"><%= lesson.description || '' %></p></div></section><section class="section"><div class="container academy-detail__content"><a class="button button--ghost" href="/akademia/kurs/<%= encodeURIComponent(course.slug) %>">← Wróć do kursu</a><article class="academy-lesson-content"><p class="course-card__tag"><%= lesson.content_type %></p><div class="academy-lesson-content__body"><%= lesson.content || 'Treść lekcji zostanie dodana.' %></div><button class="button" type="button" data-lesson-complete data-lesson-id="<%= lesson.id %>" <%= progress && progress.completed_at ? 'disabled' : '' %>><%= progress && progress.completed_at ? 'Lekcja ukończona' : 'Oznacz jako ukończoną' %></button><p class="form-status" data-lesson-status aria-live="polite"></p></article></div></section></main>
    <script src="/assets/js/menu.js" defer></script><script src="/assets/js/academy.js?v=4" defer></script>
  </body>
</html>
