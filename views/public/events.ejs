<!doctype html>
<html lang="pl">
  <head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="icon" type="image/png" href="/assets/favicon-144x144.png">
    <meta name="description" content="Wydarzenia Polskiego Budownictwa: spotkania i rozmowy branżowe.">
    <title>Wydarzenia | Polskie Budownictwo</title>
    <link rel="stylesheet" href="/global.css?v=5">
  </head>
  <body>
    <header class="site-header">
      <div class="container site-header__inner">
        <a class="site-logo" href="/" aria-label="Polskie Budownictwo - strona główna">
          <img src="/assets/images/logo.png" alt="Polskie Budownictwo">
        </a>
        <button class="site-menu-toggle" type="button" aria-controls="site-nav" aria-expanded="false" aria-label="Otwórz menu">
          <span></span><span></span><span></span>
        </button>
        <nav class="site-nav" id="site-nav" aria-label="Główna nawigacja">
          <a href="/#misja">Misja</a>
          <a href="/#dzialania">Obszary działania</a>
          <a href="/wydarzenia" aria-current="page">Wydarzenia</a>
          <a href="/#spolecznosc">Społeczność</a>
          <a href="/#kontakt">Kontakt</a>
          <a class="button button--nav" href="/#dolacz">Dołącz bezpłatnie</a>
        </nav>
        <a class="button button--nav site-header__mobile-cta" href="/#dolacz">Dołącz</a>
      </div>
    </header>

    <main>
      <section class="section" aria-labelledby="events-title">
        <div class="container">
          <header class="section-heading">
            <p class="eyebrow">Wydarzenia</p>
            <h1 id="events-title">Spotkania i rozmowy branżowe</h1>
            <p>W jednym miejscu zbieramy informacje o najbliższych aktywnościach inicjatywy i materiałach dla firm z branży budowlanej.</p>
          </header>

          <% if (error) { %>
            <p class="alert"><%= error %></p>
          <% } else if (!events.length) { %>
            <p class="events-empty">Wkrótce pojawią się tutaj informacje o wydarzeniach.</p>
          <% } else { %>
            <div class="events-list">
              <% events.forEach(event => { %>
                <article class="card event-card">
                  <p class="event-card__meta">
                    <%= formatDate(event.event_date) %>, <%= formatTime(event.event_time) %>
                    <% if (typeof isPast === 'function' && isPast(event.event_date)) { %> · Spotkanie odbyło się<% } %>
                  </p>
                  <h2><%= event.title %></h2>
                  <p class="event-card__description"><%= event.description %></p>
                </article>
              <% }) %>
            </div>
          <% } %>
        </div>
      </section>
    </main>

    <footer class="site-footer">
      <div class="container site-footer__inner">
        <a class="site-logo site-logo--footer" href="/" aria-label="Polskie Budownictwo">
          <img src="/assets/images/logo.png" alt="Polskie Budownictwo">
        </a>
        <p>© 2026 Polskie Budownictwo. Wszelkie prawa zastrzeżone.</p>
        <nav class="site-footer__links" aria-label="Dokumenty prawne">
          <a href="/#kontakt">Kontakt</a>
          <a href="/#dolacz">Dołącz</a>
        </nav>
      </div>
    </footer>
    <script src="/assets/js/menu.js" defer></script>
  </body>
</html>
