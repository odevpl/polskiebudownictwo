<!doctype html>
<html lang="pl">
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <link rel="icon" type="image/png" href="/assets/favicon-144x144.png">
    <title><%= title %> - Polskie Budownictwo</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/css/admin.css?v=8">
    <script src="/js/admin.js?v=2" defer></script>
  </head>
  <body>
    <div class="admin-shell">
      <aside class="sidebar">
        <img src="/assets/images/logo.png" alt="Polskie Budownictwo">
        <nav aria-label="Panel admina">
          <a href="<%= adminUrl('/submissions') %>" <%= title === 'Zgloszenia' || title.startsWith('Edycja') || title === 'Nowe zgloszenie' ? 'aria-current="page"' : '' %>>Zgloszenia</a>
          <a href="<%= adminUrl('/events') %>" <%= title === 'Wydarzenia' ? 'aria-current="page"' : '' %>>Wydarzenia</a>
          <a href="<%= adminUrl('/academy/courses') %>" <%= title === 'Akademia' || title.startsWith('Edycja kursu') || title === 'Nowy kurs' ? 'aria-current="page"' : '' %>>Akademia</a>
          <a href="<%= adminUrl('/academy/orders') %>" <%= title === 'Zamówienia Akademii' || title.startsWith('Zamówienie #') ? 'aria-current="page"' : '' %>>Zamówienia</a>
          <a href="<%= adminUrl('/academy/access') %>" <%= title === 'Dostępy Akademii' ? 'aria-current="page"' : '' %>>Dostępy</a>
          <a href="<%= adminUrl('/academy/users') %>" <%= title === 'Użytkownicy Akademii' ? 'aria-current="page"' : '' %>>Użytkownicy</a>
        </nav>
      </aside>
      <main class="admin-main">
        <header class="topbar">
          <span class="muted"><%= admin.fullName %></span>
          <form method="post" action="<%= adminUrl('/logout') %>">
            <button class="button button--ghost" type="submit">Wyloguj</button>
          </form>
        </header>
